# Ecommerce Agent (ADK) - local env example
#
# Copy to `agent/.env` for local ADK Web runs.
# Never commit real secrets.

# --- Gemini API (recommended default) ---
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Optional Vertex AI backend ---
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Model selection ---
MODEL_NAME=gemini-2.5-pro

# --- Agent behavior ---
MAX_RESULTS=15
LOG_LEVEL=INFO

# --- Saf3AI (optional) ---
# SAF3AI_API_KEY=...
# SAF3AI_COLLECTOR_AGENT=...
# SAF3AI_AGENT_ID=ecommerce-agent
# SAF3AI_SERVICE_NAME=ecommerce-agent
# SAF3AI_SCANNER_ENDPOINT=...
# SECURITY_SCAN_ENABLED=false
# THREAT_ACTION_LEVEL=BLOCK
# SECURITY_API_ENDPOINT=
# SECURITY_API_KEY=...
# SECURITY_API_TIMEOUT=30

